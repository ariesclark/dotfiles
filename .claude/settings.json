{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill(humanizer)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/aries/.config/lnk/.claude/statusline.sh",
    "refreshInterval": 1
  },
  "enabledPlugins": {
    "ask-questions-if-underspecified@trailofbits": true,
    "modern-python@trailofbits": false,
    "agentic-actions-auditor@trailofbits": true,
    "audit-context-building@trailofbits": true,
    "constant-time-analysis@trailofbits": true,
    "differential-review@trailofbits": true,
    "dimensional-analysis@trailofbits": true,
    "insecure-defaults@trailofbits": true,
    "fp-check@trailofbits": false,
    "sharp-edges@trailofbits": true,
    "skill-improver@trailofbits": false,
    "static-analysis@trailofbits": true,
    "supply-chain-risk-auditor@trailofbits": true,
    "testing-handbook-skills@trailofbits": true,
    "workflow-skill-design@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true,
    "claude-md-management@claude-plugins-official": true,
    "prior-art@ariesclark": true,
    "humanizer@ariesclark": true,
    "sentry-cli@claude-plugins-official": true,
    "guardrails@ariesclark": true,
    "github@ariesclark": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      },
      "autoUpdate": true
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      },
      "autoUpdate": true
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "ariesclark": {
      "source": {
        "source": "directory",
        "path": "/home/aries/skills"
      }
    }
  },
  "effortLevel": "medium",
  "skipWorkflowUsageWarning": true,
  "verbose": true,
  "remoteControlAtStartup": true,
  "tui": "fullscreen"
}
